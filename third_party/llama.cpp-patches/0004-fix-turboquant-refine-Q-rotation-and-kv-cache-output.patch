From 9930c7819246cb97caee1ea67c7dfa686f6aa482 Mon Sep 17 00:00:00 2001
From: mkamar <mohamad.kamar@agoda.com>
Date: Mon, 30 Mar 2026 23:25:40 +0700
Subject: [PATCH 4/5] fix(turboquant): refine Q rotation and kv-cache output

---
 ggml/include/ggml.h    | 11 ++++++++++-
 ggml/src/ggml.c        | 29 ++++++++++++++++++++++++++++-
 src/llama-kv-cache.cpp |  6 ++++++
 3 files changed, 44 insertions(+), 2 deletions(-)

diff --git a/ggml/include/ggml.h b/ggml/include/ggml.h
index 566e27147..91a36032f 100644
--- a/ggml/include/ggml.h
+++ b/ggml/include/ggml.h
@@ -427,7 +427,9 @@ extern "C" {
         // GGML_TYPE_IQ4_NL_4_8 = 37,
         // GGML_TYPE_IQ4_NL_8_8 = 38,
         GGML_TYPE_MXFP4   = 39, // MXFP4 (1 block)
-        GGML_TYPE_COUNT   = 40,
+        GGML_TYPE_TQ_Q3_LM = 40, // TurboQuant 3-bit Lloyd-Max (custom, block_size=32, 14 bytes/block)
+        GGML_TYPE_TQ_Q2_LM = 41, // TurboQuant 2-bit Lloyd-Max (custom, block_size=32, 10 bytes/block)
+        GGML_TYPE_COUNT   = 42,
     };
 
     // precision
@@ -2726,6 +2728,13 @@ extern "C" {
 
     GGML_API const struct ggml_type_traits * ggml_get_type_traits(enum ggml_type type);
 
+    // Register custom quantize/dequantize functions for a type at runtime.
+    // The type must already have a valid entry (non-zero blck_size) in the traits table.
+    GGML_API void ggml_set_type_trait_fns(
+        enum ggml_type type,
+        ggml_to_float_t   to_float,
+        ggml_from_float_t from_float_ref);
+
     // ggml threadpool
     // TODO: currently, only a few functions are in the base ggml API, while the rest are in the CPU backend
     // the goal should be to create an API that other backends can use move everything to the ggml base
diff --git a/ggml/src/ggml.c b/ggml/src/ggml.c
index aeafc395d..6766adfec 100644
--- a/ggml/src/ggml.c
+++ b/ggml/src/ggml.c
@@ -606,7 +606,7 @@ FILE * ggml_fopen(const char * fname, const char * mode) {
 
 }
 
-static const struct ggml_type_traits type_traits[GGML_TYPE_COUNT] = {
+static struct ggml_type_traits type_traits[GGML_TYPE_COUNT] = {
     [GGML_TYPE_I8] = {
         .type_name                = "i8",
         .blck_size                = 1,
@@ -896,6 +896,22 @@ static const struct ggml_type_traits type_traits[GGML_TYPE_COUNT] = {
         .type_size                = 0,
         .is_quantized             = false,
     },
+    [GGML_TYPE_TQ_Q3_LM] = {
+        .type_name                = "tq_q3_lm",
+        .blck_size                = 32,
+        .type_size                = 14,
+        .is_quantized             = true,
+        .to_float                 = NULL,
+        .from_float_ref           = NULL,
+    },
+    [GGML_TYPE_TQ_Q2_LM] = {
+        .type_name                = "tq_q2_lm",
+        .blck_size                = 32,
+        .type_size                = 10,
+        .is_quantized             = true,
+        .to_float                 = NULL,
+        .from_float_ref           = NULL,
+    },
 };
 
 const struct ggml_type_traits * ggml_get_type_traits(enum ggml_type type) {
@@ -904,6 +920,17 @@ const struct ggml_type_traits * ggml_get_type_traits(enum ggml_type type) {
     return &type_traits[type];
 }
 
+void ggml_set_type_trait_fns(
+        enum ggml_type type,
+        ggml_to_float_t   to_float,
+        ggml_from_float_t from_float_ref) {
+    assert(type >= 0);
+    assert(type < GGML_TYPE_COUNT);
+    assert(type_traits[type].blck_size > 0);
+    type_traits[type].to_float       = to_float;
+    type_traits[type].from_float_ref = from_float_ref;
+}
+
 //
 // ggml object
 //
diff --git a/src/llama-kv-cache.cpp b/src/llama-kv-cache.cpp
index d326c1a8a..d13ded639 100644
--- a/src/llama-kv-cache.cpp
+++ b/src/llama-kv-cache.cpp
@@ -1187,6 +1187,12 @@ ggml_tensor * llama_kv_cache::cpy_v(ggml_context * ctx, ggml_tensor * v_cur, ggm
         v_cur = ggml_cont_2d   (ctx, v_cur, n_embd_gqa, n_tokens);
     }
 
+    // Apply rotation before transposition so V is stored in the same rotated
+    // coordinate space as K (matches the non-v_trans path above).
+    if (rotation_hook && rotation_hook_userdata) {
+        v_cur = ggml_map_custom1(ctx, v_cur, rotation_hook, GGML_N_TASKS_MAX, rotation_hook_userdata[il]);
+    }
+
     // [TAG_V_CACHE_VARIABLE]
     if (n_embd_gqa < v->ne[0]) {
         v_cur = ggml_pad(ctx, v_cur, v->ne[0] - n_embd_gqa, 0, 0, 0);
-- 
2.50.1 (Apple Git-155)

